# /etc/ctp/booth.env — photobooth runtime configuration
#
# Loaded by booth.service via EnvironmentFile=-/etc/ctp/booth.env.
# Copy to /etc/ctp/booth.env and uncomment any line you want to override.
# A commented or missing key falls back to the Python-level default in
# photobooth/booth_main.py.
#
# After editing: sudo systemctl restart booth.service

# S3 bucket for uploaded captures (must exist with public read policy)
#BOOTH_S3_BUCKET=public.capturingtimephoto.net

# Local archive dir for full-resolution captures (must be writable by root)
#BOOTH_IMAGE_DIR=/opt/booth_images

# gphoto2 camera model string — must match a connected USB camera exactly
#BOOTH_CAMERA_MODEL=Canon EOS 800D

# Max receipt reprints per single capture (integer)
#BOOTH_MAX_PRINTS=3

# Compositor template root and active template folder name.
# Leave BOOTH_ACTIVE_TEMPLATE empty to use plain single-shot mode (no compositor).
#BOOTH_TEMPLATE_BASE_DIR=/opt/photobooth/templates
#BOOTH_ACTIVE_TEMPLATE=strip_test_template
